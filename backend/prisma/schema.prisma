generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  GITHUB
  GOOGLE
  EMAIL
}

enum Theme {
  DARK
  LIGHT
  SYSTEM
}

enum WeekStart {
  SUNDAY
  MONDAY
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  name         String
  avatarUrl    String?
  provider     AuthProvider
  providerId   String?
  refreshToken String?
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  settings UserSettings?

  @@unique([provider, providerId])
  @@map("users")
}

model UserSettings {
  id                      String    @id @default(uuid()) @db.Uuid
  userId                  String    @unique @db.Uuid
  theme                   Theme     @default(DARK)
  timezone                String    @default("UTC")
  defaultPlanStartTime    String    @default("09:00")
  defaultPlanEndTime      String    @default("22:00")
  pomodoroWorkMinutes     Int       @default(25)
  pomodoroBreakMinutes    Int       @default(5)
  pomodoroLongBreakMinutes Int      @default(15)
  weekStartsOn            WeekStart @default(MONDAY)
  emailNotifications      Boolean   @default(true)
  pushNotifications       Boolean   @default(false)
  dailyPlanningReminder   Boolean   @default(true)
  dailyReviewReminder     Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
